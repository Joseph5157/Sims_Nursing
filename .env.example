# ─── Branding ─────────────────────────────────────────────────────────────────
# Used in server-generated text: Telegram bot messages, PDF report headers,
# startup log line. Read at process start — no rebuild needed (unlike the
# client's VITE_-prefixed equivalents in client/.env.example, which are
# baked in at build time).
APP_SHORT_NAME=SIMS Nursing DMS

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/sims_dms

# ─── Application URL ──────────────────────────────────────────────────────────
# Public URL of the deployed app — used for CORS validation and link generation.
# Example (Railway): https://simsdms-production.up.railway.app
APP_URL=https://your-app.up.railway.app

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Use a long random string (64+ hex chars). Never commit the real value.
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# ─── Telegram Bot ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_BOT_USERNAME=your_bot_username_without_at_sign

# ─── Telegram Webhook ─────────────────────────────────────────────────────────
# Set to a long random string (64+ chars). Sent in the URL path when registering
# the webhook, and/or via X-Telegram-Bot-Api-Secret-Token header.
TELEGRAM_WEBHOOK_SECRET=replace_with_long_random_string

# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# Timezone — REQUIRED in production so date calculations (check-in thresholds,
# auto clock-out cron, calendar auto-close) match India Standard Time.
# Set this in Railway → Variables → TZ=Asia/Kolkata
TZ=Asia/Kolkata

# ─── CORS ─────────────────────────────────────────────────────────────────────
# In production, set to your exact frontend URL (no trailing slash).
# For development with Vite: http://localhost:5173
# Multiple origins: CORS_ORIGIN=https://app.example.com,https://www.example.com
CORS_ORIGIN=http://localhost:5173

# ─── Bootstrap Super Admin (local setup only) ─────────────────────────────────
# Required only when running: npx prisma db seed
# Run once on a fresh database to create the first Super Admin account.
# Get your TELEGRAM_ID by messaging the bot and sending /myid
BOOTSTRAP_SUPER_ADMIN_EMAIL=admin@sims.local
BOOTSTRAP_SUPER_ADMIN_NAME=SIMS Super Admin
BOOTSTRAP_SUPER_ADMIN_TELEGRAM_ID=your_telegram_numeric_id
BOOTSTRAP_SUPER_ADMIN_PHONE=
BOOTSTRAP_SUPER_ADMIN_DEPARTMENT=Administration
BOOTSTRAP_SUPER_ADMIN_DESIGNATION=Super Admin
# Optional — set this to pin the initial login password. If left unset, the
# seed script generates a random password and prints it to the console once
# (never written to disk in plaintext); the account is forced to change it
# on first login via must_change_password.
BOOTSTRAP_SUPER_ADMIN_PASSWORD=
