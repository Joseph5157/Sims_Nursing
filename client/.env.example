# Environment variables for SIMS DMS client
# Note: API_URL is configured in vite.config.js based on the environment

# ─── Branding ─────────────────────────────────────────────────────────────────
# Baked in at build time (Vite) — changing these requires a rebuild + redeploy.
# Also used for %VITE_...% replacement in index.html (title, meta description).
VITE_INSTITUTION_NAME=SIMS College of Nursing
VITE_APP_SHORT_NAME=SIMS Nursing DMS

# ─── Telegram (magic-link login) ──────────────────────────────────────────────
# Bot username (no @) — used to build the "Log in via Telegram" deep link
# (https://t.me/<username>?start=login) on the login page. Must match the
# TELEGRAM_BOT_USERNAME configured on the server.
VITE_TELEGRAM_BOT_USERNAME=your_bot_username_without_at_sign
