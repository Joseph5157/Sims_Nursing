# Environment variables for SIMS DMS client
# Note: API_URL is configured in vite.config.js based on the environment

# ─── Branding ─────────────────────────────────────────────────────────────────
# Baked in at build time (Vite) — changing these requires a rebuild + redeploy.
# Also used for %VITE_...% replacement in index.html (title, meta description).
VITE_INSTITUTION_NAME=SIMS College of Pharmacy
VITE_APP_SHORT_NAME=SIMS DMS
